# syntax=docker/dockerfile:1
FROM golang:1.22-alpine AS build
WORKDIR /src
COPY go.mod ./
RUN go mod download
COPY . ./
RUN GOCACHE=/tmp/go-build CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -o /out/client ./cmd/client

FROM alpine:3.19
WORKDIR /app
COPY --from=build /out/client /app/client
ENTRYPOINT ["/app/client"]
